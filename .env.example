# Database
# SQLite (development, default)
DATABASE_URL=sqlite+aiosqlite:///./data/oco.db
# PostgreSQL (production): postgresql+asyncpg://user:pass@host/dbname

# Security — CHANGE IN PRODUCTION
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin iniziale (usato solo da init_db.py al primo avvio)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-this-password

# Storage (percorso dove vengono salvate le foto)
STORAGE_PATH=./data/media

# AI provider: ollama | claude | mistral
AI_PROVIDER=ollama
AI_TIMEOUT_SECONDS=60

# Ollama (default provider — modello consigliato: llava-llama3)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llava-llama3
# Timeout for Ollama requests (seconds) — increase for slow hardware
OLLAMA_TIMEOUT_SECONDS=300
# Max concurrent requests to Ollama (1 = sequential, matches Ollama's default single-slot config)
OLLAMA_CONCURRENCY=1

# Claude API (opzionale — solo se AI_PROVIDER=claude)
CLAUDE_API_KEY=

# Mistral API (opzionale — solo se AI_PROVIDER=mistral)
MISTRAL_API_KEY=

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# App
APP_HOST=http://localhost:3000
LOG_LEVEL=INFO
# Set LOG_JSON=true for structured JSON logs in production
LOG_JSON=false

# CORS origins (lista separata da virgole)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Upload limits
MAX_UPLOAD_SIZE_MB=20

# Rate limiting (format: N/period, period: second/minute/hour)
LOGIN_RATE_LIMIT=10/minute
